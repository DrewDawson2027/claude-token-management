          "minLength": 1
        },
        "session_key": {
          "type": "string"
        },
        "session": {
          "type": "string"
        },
        "decision_id": {
          "type": "string"
        },
        "input_tokens": {
          "type": "integer"
        },
        "output_tokens": {
          "type": "integer"
        },
        "cache_read_tokens": {
          "type": "integer"
