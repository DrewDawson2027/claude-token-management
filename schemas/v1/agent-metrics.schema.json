    {
      "type": "object",
      "required": [
        "schema_version",
        "record_type",
        "ts",
        "event",
        "agent_type",
        "agent_id",
        "session_key",
        "session",
        "decision_id",
        "input_tokens",
        "output_tokens",
        "cache_read_tokens",
        "cache_creation_tokens",
        "api_calls",
        "total_tokens",
        "cost_usd",
        "pricing_model"
