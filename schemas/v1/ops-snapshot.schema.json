{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-token-management.local/schemas/v1/ops-snapshot.schema.json",
  "title": "Ops Snapshot",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "time_window",
    "budget",
    "spend",
    "alerts",
    "blocks",
    "agents",
    "sessions",
    "self_heal",
    "anomalies",
    "data_quality",
    "sources",
    "timeline"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "time_window": {
      "type": "object"
    },
    "budget": {
      "type": "object"
    },
    "spend": {
      "type": "object"
    },
    "alerts": {
      "type": "object"
    },
    "blocks": {
      "type": "object"
    },
    "agents": {
      "type": "object"
    },
    "sessions": {
      "type": "object"
    },
    "self_heal": {
      "type": "object"
    },
    "anomalies": {
      "type": "object"
    },
    "data_quality": {
      "type": "object"
    },
    "sources": {
      "type": "object",
      "additionalProperties": {
        "type": "object"
      }
    },
    "timeline": {
      "type": "array"
    }
  },
  "additionalProperties": true
}
