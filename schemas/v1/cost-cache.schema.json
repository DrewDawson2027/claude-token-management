{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://claude-token-management.local/schemas/v1/cost-cache.schema.json",
  "title": "Cost Cache",
  "type": "object",
  "required": [
    "generatedAt",
    "source",
    "windows"
  ],
  "properties": {
    "generatedAt": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "windows": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/windowRecord"
      }
    }
  },
  "$defs": {
    "windowRecord": {
      "type": "object",
      "required": [
        "generatedAt",
        "window",
        "filters",
        "source",
        "local"
      ],
      "properties": {
        "generatedAt": {
          "type": "string",
          "minLength": 1
        },
        "window": {
          "type": "string",
          "minLength": 1
        },
        "filters": {
          "type": "object",
          "required": [
            "since",
            "until",
            "team_id",
            "session_id",
            "project"
          ],
          "additionalProperties": true
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "ccusage": {
          "type": "object"
        },
        "local": {
          "type": "object",
          "required": [
            "source",
            "filteredMessages",
            "totals",
            "models",
            "sessions"
          ],
          "additionalProperties": true
        },
        "totals": {
          "type": "object"
        },
        "budget": {
          "type": "object"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
