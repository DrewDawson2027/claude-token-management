  "model": "claude-sonnet-4-6",
  "hooks": {
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-end.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/teammate-lifecycle.sh TeammateIdle",
            "timeout": 1000
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/teammate-lifecycle.sh TaskCompleted",
            "timeout": 1000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-inbox.sh",
            "timeout": 1000
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/token-guard.py",
            "timeout": 1000
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/model-router.py",
            "timeout": 1000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/read-efficiency-guard.py",
            "timeout": 1000
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash|Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/terminal-heartbeat.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/session-register.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "outputStyle": "Explanatory",
  "thinkingEnabled": true,
  "mcpServers": {
    "coordinator": {
      "command": "/opt/homebrew/Cellar/node/25.6.1_1/bin/node",
      "args": [
        "/Users/drewdawson/.claude/mcp-coordinator/index.js"
      ]
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "serena": {
      "command": "uvx",
      "args": [
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--project-from-cwd"
      ]
    },
    "typescript-lsp": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-lsp-bridge@latest"
      ]
    },
    "pyright-lsp": {
      "command": "npx",
      "args": [
        "-y",
        "@treedy/lsp-mcp@latest"
      ]
    },
    "github": {
      "command": "bash",
      "args": [
        "-lc",
        "GITHUB_PERSONAL_ACCESS_TOKEN=\"${GITHUB_TOKEN:-$(gh auth token 2>/dev/null)}\" exec npx -y @modelcontextprotocol/server-github@latest"
      ]
    },
    "notion": {
      "type": "http",
      "url": "https://mcp.notion.com/mcp"
    },
    "postgres": {
      "command": "bash",
      "args": [
        "-lc",
        "exec npx -y @modelcontextprotocol/server-postgres@latest \"${DATABASE_URL:-postgresql://localhost/postgres}\""
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking@latest"
      ]
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "n8n": {
      "command": "npx",
      "args": [
        "-y",
        "n8n-mcp"
      ]
    }
  }
}